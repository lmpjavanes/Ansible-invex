<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Linux Users Admin</title>
  <style>
    body { font-family: Arial, sans-serif; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ddd; padding: 8px; vertical-align: top; }
    th { background: #f2f2f2; position: sticky; top: 0; }
    .bad { color: #b00020; font-weight: bold; }
    .ok  { color: #1b5e20; font-weight: bold; }
    .mono { font-family: Consolas, Monaco, monospace; font-size: 12px; white-space: pre-wrap; }
  </style>
</head>
<body>
  <h2>Linux Users Admin</h2>
  <p>Reporte consolidado del rol <b>users-admin</b> (crear/eliminar usuarios) por host y por usuario.</p>

  <table>
    <tr>
      <th>Host</th>
      <th>Checked at</th>
      <th>Host status</th>
      <th>Operación</th>
      <th>Usuario</th>
      <th>Acción</th>
      <th>Tipo</th>
      <th>Grupo</th>
      <th>Extra groups</th>
      <th>Home</th>
      <th>Shell</th>
      <th>Changed</th>
      <th>Status</th>
      <th>Chage info</th>
      <th>Mensaje</th>
    </tr>

    {% for h in (audit_linux | default([])) %}
      {% set ops = h.operations | default([]) %}
      {% if ops | length == 0 %}
        <tr>
          <td>{{ h.host | default('') }}</td>
          <td>{{ h.checked_at | default('') }}</td>
          <td class="{{ 'bad' if (h.status | default('')) != 'ok' else 'ok' }}">{{ h.status | default('') }}</td>
          <td>{{ h.operation | default('') }}</td>
          <td></td><td></td><td></td><td></td><td></td><td></td><td></td>
          <td></td>
          <td class="bad">{{ h.status | default('') }}</td>
          <td class="mono"></td>
          <td class="bad">{{ h.message | default('') }}</td>
        </tr>
      {% else %}
        {% for op in ops %}
        <tr>
          <td>{{ h.host | default('') }}</td>
          <td>{{ h.checked_at | default('') }}</td>
          <td class="{{ 'bad' if (h.status | default('')) != 'ok' else 'ok' }}">{{ h.status | default('') }}</td>
          <td>{{ h.operation | default('') }}</td>
          <td>{{ op.username | default('') }}</td>
          <td>{{ op.action | default('') }}</td>
          <td>{{ op.user_type | default('') }}</td>
          <td>{{ op.group | default('') }}</td>
          <td>{{ (op.extra_groups | default([])) | join(', ') if (op.extra_groups | default([]) | length) > 0 else '' }}</td>
          <td>{{ op.home | default('') }}</td>
          <td>{{ op.shell | default('') }}</td>
          <td>{{ op.changed | default(false) }}</td>
          <td class="{{ 'bad' if (op.status | default('')) != 'ok' else 'ok' }}">{{ op.status | default('') }}</td>
          <td class="mono">{{ op.chage_info | default('') }}</td>
          <td class="{{ 'bad' if (op.status | default('')) != 'ok' else '' }}">{{ op.message | default('') }}</td>
        </tr>
        {% endfor %}
      {% endif %}
    {% endfor %}

  </table>
</body>
</html>